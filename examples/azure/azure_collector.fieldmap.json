{
  "source_system": "azure_activity_log",
  "event_type": "resource_access",
  "fields": {
    "_native_actor_id": {
      "source_path": [
        "claims.oid",
        "caller"
      ],
      "required": true
    },
    "_event_time": {
      "source_path": "eventTimestamp",
      "transform": "parse_iso8601",
      "required": true
    },
    "action": {
      "source_path": "operationName.value",
      "required": true
    },
    "outcome": {
      "source_path": "status.value",
      "transform": "azure_status_to_outcome",
      "default": "unknown"
    },
    "resource.resource_name": {
      "source_path": "resourceId",
      "default": "unknown_resource"
    }
  }
}
