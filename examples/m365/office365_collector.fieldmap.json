{
  "source_system": "office365",
  "event_type": "resource_access",
  "fields": {
    "_native_actor_id": {
      "source_path": "UserId",
      "required": true
    },
    "_event_time": {
      "source_path": "CreationTime",
      "transform": "parse_iso8601",
      "required": true
    },
    "action": {
      "source_path": "Operation",
      "required": true
    },
    "outcome": {
      "source_path": "ResultStatus",
      "transform": "o365_status_to_outcome",
      "default": "unknown"
    },
    "resource.resource_name": {
      "source_path": ["MailboxOwnerUPN", "Workload"],
      "default": "unknown_target"
    }
  }
}
