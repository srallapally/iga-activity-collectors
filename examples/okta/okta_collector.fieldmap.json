{
  "source_system": "okta",
  "event_type": "resource_access",
  "fields": {
    "_native_actor_id": {
      "source_path": ["actor.alternateId", "actor.displayName"],
      "required": true
    },
    "_event_time": {
      "source_path": "published",
      "transform": "parse_iso8601",
      "required": true
    },
    "action": {
      "source_path": "eventType",
      "required": true
    },
    "outcome": {
      "source_path": "outcome.result",
      "transform": "sailpoint_result_to_outcome",
      "default": "unknown"
    },
    "resource.resource_name": {
      "source_path": ["target[0].alternateId", "target[0].displayName"],
      "default": "unknown_target"
    }
  }
}