{
  "source_system": "jaeger",
  "event_type": "tool_invocation",
  "fields": {
    "_native_actor_id": {
      "source_path": "user",
      "required": true
    },
    "_event_time": {
      "source_path": "startTime",
      "transform": "micros_to_datetime",
      "required": true
    },
    "action": {
      "source_path": "action",
      "required": true
    },
    "outcome": {
      "source_path": "_resolved_result",
      "transform": "sailpoint_result_to_outcome",
      "default": "unknown"
    },
    "resource.resource_name": {
      "source_path": "target",
      "default": "unknown_service"
    }
  }
}