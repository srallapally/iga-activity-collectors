{
  "source_system": "google_workspace",
  "event_type": "authentication",
  "fields": {
    "_native_actor_id": {
      "source_path": "actor_id",
      "required": true
    },
    "_event_time": {
      "source_path": "time",
      "transform": "parse_iso8601",
      "required": true
    },
    "action": {
      "source_path": "action",
      "required": true
    },
    "outcome": {
      "source_path": "_resolved_result",
      "transform": "sailpoint_result_to_outcome",
      "default": "unknown"
    },
    "resource.resource_name": {
      "source_path": "applicationName",
      "default": "unknown_app"
    }
  }
}
