{
  "source_system": "entra_id",
  "event_type": "resource_access",
  "fields": {
    "_native_actor_id": {
      "source_path": [
        "initiatedBy.user.userPrincipalName",
        "initiatedBy.servicePrincipal.displayName"
      ],
      "required": true
    },
    "_event_time": {
      "source_path": "activityDateTime",
      "transform": "parse_iso8601",
      "required": true
    },
    "action": {
      "source_path": "activityDisplayName",
      "default": "unknown_activity"
    },
    "outcome": {
      "source_path": "result",
      "transform": "sailpoint_result_to_outcome",
      "default": "unknown"
    },
    "resource.resource_name": {
      "source_path": ["targetResources[0].userPrincipalName", "targetResources[0].displayName"],
      "default": "unknown_target"
    }
  }
}
