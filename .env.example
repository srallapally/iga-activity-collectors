# IGA server
IGA_PROTOCOL=https
IGA_HOST=your-iga-host.example.com
IGA_PORT=443
IGA_UPLOAD_PATH=/iga/governance/activity

# OAuth2 client credentials
IGA_TOKEN_URL=https://your-iga-host.example.com/oauth/token
IGA_CLIENT_ID=your-client-id
IGA_CLIENT_SECRET=your-client-secret
# IGA_OAUTH_SCOPE=

# Collector runtime
# Mount your collectors directory to /collectors:  -v /host/collectors:/collectors
# Mount your state directory to /state:            -v /host/state:/state
# COLLECTORS_DIR and CHECKPOINT_STORE_PATH are set in the Dockerfile and do not need to be overridden.

# Logging (optional)
# LOG_LEVEL=INFO
# One of DEBUG, INFO, WARNING, ERROR. Default: INFO

# LOG_FORMAT=text
# Use "json" for structured log aggregation (ELK, Datadog, CloudWatch, Splunk).

# Dry run / testing (optional)
# DRY_RUN=false
# Set to true to print events to stdout instead of uploading. IGA credentials not required.

# LIMIT=
# Stop each collector after N events. Works with or without DRY_RUN.
