# IGA server
IGA_PROTOCOL=https
IGA_HOST=your-iga-host.example.com
IGA_PORT=443
IGA_UPLOAD_PATH=/iga/governance/activity

# OAuth2 client credentials
IGA_TOKEN_URL=https://your-iga-host.example.com/oauth/token
IGA_CLIENT_ID=your-client-id
IGA_CLIENT_SECRET=your-client-secret
# IGA_OAUTH_SCOPE=                  # optional — set if your token endpoint requires a scope

# Collector runtime
COLLECTORS_DIR=/collectors          # mount your collectors directory here
CHECKPOINT_STORE_PATH=/state/checkpoint.json   # must be on persistent storage
